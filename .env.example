# Copy this file to .env and fill in actual values
# NEVER commit .env to git

# ─── LLM ───────────────────────────────────────
# Groq API for synthesis (free tier: console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ─── Model Hub ─────────────────────────────────
# Hugging Face Hub token for loading fine-tuned model
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ─── Paper APIs ────────────────────────────────
# Semantic Scholar (optional, increases rate limit)
# Register: https://www.semanticscholar.org/product/api
S2_API_KEY=your_semantic_scholar_key_or_leave_blank

# OpenAlex (just an email, improves rate limit)
# No registration needed
OPENALEX_EMAIL=your_email@example.com

# PubMed E-utilities (optional, increases rate limit)
# Get from: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_pubmed_key_or_leave_blank

# ─── App Config ────────────────────────────────
# Backend URL for Streamlit to call
BACKEND_URL=http://localhost:8000

# Log level
LOG_LEVEL=INFO